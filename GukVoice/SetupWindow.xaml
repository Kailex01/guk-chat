<Window x:Class="GukVoice.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GukVoice — First-time Setup" Height="300" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="GukVoice Setup"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="18" FontWeight="Bold"/>

        <!-- EQ Log File -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="EQ Log File" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="LogPathBox" Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         IsReadOnly="True" Cursor="Arrow"/>
                <Button Grid.Column="2" Content="Browse…"
                        Style="{StaticResource DarkButton}"
                        Click="BrowseLog_Click"/>
            </Grid>
            <TextBlock Text="Typically: Documents\EverQuest\Logs\eqlog_CharName_Server.txt"
                       Foreground="{StaticResource SubtextBrush}" FontSize="10" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Character Name -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Your Character Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="PlayerNameBox" Style="{StaticResource DarkTextBox}"
                     ToolTip="Used to identify your own /say lines in the log"/>
        </StackPanel>

        <!-- Archive folder (optional) -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="Archive Folder (optional — leave blank to use app folder)"
                       Style="{StaticResource FieldLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ArchiveFolderBox" Grid.Column="0"
                         Style="{StaticResource DarkTextBox}" IsReadOnly="True" Cursor="Arrow"/>
                <Button Grid.Column="2" Content="Browse…"
                        Style="{StaticResource DarkButton}"
                        Click="BrowseArchive_Click"/>
            </Grid>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource DarkButton}"
                    IsCancel="True" Margin="0,0,8,0"/>
            <Button Content="Save and Continue" Style="{StaticResource DarkButton}"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
