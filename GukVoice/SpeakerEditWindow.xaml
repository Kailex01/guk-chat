<Window x:Class="GukVoice.SpeakerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speaker" Height="560" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Speaker Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource DarkTextBox}"
                     ToolTip="Exact name as it appears in the EQ log (case-insensitive)"/>
        </StackPanel>

        <!-- Type -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="TypeBox" Style="{StaticResource DarkComboBox}">
                <ComboBoxItem Content="NPC"/>
                <ComboBoxItem Content="Player"/>
                <ComboBoxItem Content="Bot"/>
            </ComboBox>
        </StackPanel>

        <!-- Enabled -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <CheckBox x:Name="EnabledBox" VerticalAlignment="Center"
                      Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="  Speak when this name appears in the log"
                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Voice Profile -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="VOICE PROFILE" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,10"/>

            <!-- Voice rows (populated in code-behind) -->
            <StackPanel x:Name="VoiceRowsPanel"/>

            <Button x:Name="AddVoiceButton" Content="+ Add Voice"
                    Style="{StaticResource DarkButton}"
                    HorizontalAlignment="Left" Margin="0,8,0,0"
                    Click="AddVoice_Click"/>
        </StackPanel>

        <!-- Sliders -->
        <Grid Grid.Row="8" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Speed -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Speed" Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center"/>
                <Slider x:Name="SpeedSlider" Grid.Column="1" Minimum="0.5" Maximum="2.0"
                        Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                        ValueChanged="SpeedSlider_ValueChanged"/>
                <TextBlock x:Name="SpeedLabel" Grid.Column="2" Text="1.00"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Pitch -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Pitch (st)" Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center"/>
                <Slider x:Name="PitchSlider" Grid.Column="1" Minimum="-12" Maximum="12"
                        Value="0" TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="PitchSlider_ValueChanged"/>
                <TextBlock x:Name="PitchLabel" Grid.Column="2" Text="0.0"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Volume -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Volume" Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center"/>
                <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0.1" Maximum="2.0"
                        Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                        ValueChanged="VolumeSlider_ValueChanged"/>
                <TextBlock x:Name="VolumeLabel" Grid.Column="2" Text="1.00"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource DarkButton}"
                    IsCancel="True" Margin="0,0,8,0"/>
            <Button Content="Save" Style="{StaticResource DarkButton}"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
