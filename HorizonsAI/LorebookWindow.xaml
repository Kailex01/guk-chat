<Window x:Class="HorizonsAI.LorebookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Lorebook"
        Width="720" Height="520"
        MinWidth="580" MinHeight="400"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F1923"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="5" CaptionHeight="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#7A8B9A"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Width="38" Height="32">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5C1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A6070"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#111E2A"/>
            <Setter Property="Foreground"   Value="#D4C5A0"/>
            <Setter Property="BorderBrush"  Value="#1E3A50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="CaretBrush"   Value="#C8A020"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"   Value="#8B6000"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="20,7"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A87800"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A2A00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#5C1A1A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7A2020"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#1E3A50"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4E6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EntryListItem" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="10,7"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#1A2E40"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#C8A020"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#080E14" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock Text="LOREBOOK" Foreground="#C8A020" FontSize="10" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="14,0"/>
            <Button Content="✕" Style="{StaticResource TitleBtn}" HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" MinWidth="160" MaxWidth="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1" Width="4" Background="#1E3A50"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

            <!-- Left: entry list -->
            <Grid Grid.Column="0" Background="#0A1018">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#080E14" BorderBrush="#1E3A50" BorderThickness="0,0,0,1">
                    <Grid Margin="12,0,8,0">
                        <TextBlock Text="ENTRIES" Foreground="#C8A020" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Content="+ Add" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource ActionBtn}" Padding="10,4" FontSize="11"
                                Click="Add_Click"/>
                    </Grid>
                </Border>

                <ListBox x:Name="EntryList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource EntryListItem}"
                         SelectionChanged="EntryList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Foreground="#D4C5A0"
                                           FontSize="12" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding KeywordsDisplay}" Foreground="#4A6070"
                                           FontSize="9" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Right: entry editor -->
            <Grid Grid.Column="2" Background="#0F1923">

                <!-- Empty state -->
                <TextBlock x:Name="EmptyHint"
                           Text="Select an entry or click + Add to create one"
                           Foreground="#4A6070" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Editor panel -->
                <Grid x:Name="EditorPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,14,20,0">
                        <StackPanel>
                            <TextBlock Text="TITLE" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TitleBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                            <TextBlock Text="KEYWORDS  (comma-separated — triggers injection when found in recent messages)"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="KeywordsBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                            <TextBlock Text="CONTENT  (injected into system prompt when a keyword matches)"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="ContentBox" Style="{StaticResource FieldBox}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Height="180" VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,14"/>

                            <CheckBox x:Name="EnabledCheck" Content="Enabled" Foreground="#D4C5A0"
                                      FontSize="12" Margin="0,0,0,4"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="#080E14" BorderBrush="#1E3A50" BorderThickness="0,1,0,0">
                        <Grid Margin="16,0">
                            <Button Content="Delete Entry" Style="{StaticResource DangerBtn}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Click="Delete_Click"/>
                            <Button Content="Save Entry" Style="{StaticResource ActionBtn}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="SaveEntry_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#080E14" BorderBrush="#1E3A50" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="EntryCountText" Foreground="#4A6070" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Content="Close" Style="{StaticResource SecondaryBtn}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
