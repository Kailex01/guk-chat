<Window x:Class="HorizonsAI.TtsSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Voice Setup"
        Width="420" Height="320"
        MinWidth="380" MinHeight="280"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F1923"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="0" CaptionHeight="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#080E14" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock Text="VOICE SETUP"
                       Foreground="#C8A020" FontSize="10" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="14,0"/>
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,20,24,0">

            <TextBlock Text="Choose a voice model to download:"
                       Foreground="#D4C5A0" FontSize="13" Margin="0,0,0,16"/>

            <!-- English only option (default) -->
            <Border x:Name="CompactBorder" Background="#111E2A" CornerRadius="6"
                    BorderBrush="#C8A020" BorderThickness="2"
                    Padding="14,10" Margin="0,0,0,8"
                    Cursor="Hand" MouseLeftButtonDown="SelectCompact_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="CompactDot" Width="12" Height="12"
                             Fill="#C8A020" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="English only  (11 voices)"
                                   Foreground="#D4C5A0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="Smaller download · EN voices only"
                                   Foreground="#4A6070" FontSize="10"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="~350 MB"
                               Foreground="#4A6070" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Multilingual option -->
            <Border x:Name="FullBorder" Background="#0A1018" CornerRadius="6"
                    BorderBrush="#1E3A50" BorderThickness="2"
                    Padding="14,10" Margin="0,0,0,16"
                    Cursor="Hand" MouseLeftButtonDown="SelectFull_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="FullDot" Width="12" Height="12"
                             Fill="Transparent" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Multilingual  (EN · JP · ZH)"
                                   Foreground="#D4C5A0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="103 voices including Japanese"
                                   Foreground="#4A6070" FontSize="10"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="~700 MB"
                               Foreground="#4A6070" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Progress area (hidden until download starts) -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                <ProgressBar x:Name="ProgressBar"
                             Height="6" Minimum="0" Maximum="100"
                             Foreground="#C8A020" Background="#1E3A50"
                             BorderThickness="0" Margin="0,0,0,6"/>
                <TextBlock x:Name="ProgressText"
                           Foreground="#4A6070" FontSize="10"
                           HorizontalAlignment="Center"/>
            </StackPanel>

        </StackPanel>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#080E14"
                BorderBrush="#1E3A50" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button x:Name="SkipBtn" Content="Skip for now"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="Transparent" Foreground="#4A6070"
                        BorderThickness="0" FontSize="12" Cursor="Hand"
                        Click="Skip_Click"/>
                <Button x:Name="DownloadBtn" Content="Download"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="#8B6000" Foreground="White"
                        BorderThickness="0" FontSize="12" FontWeight="Bold"
                        Padding="20,8" Cursor="Hand"
                        Click="Download_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#A87800"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#3A2A00"/>
                                    <Setter Property="Foreground" Value="#6A5A30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
